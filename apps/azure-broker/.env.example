# Azure broker VM public IP or DNS name
BROKER_PUBLIC_HOST=broker-public-ip-or-dns

# Keep the external ports aligned with Azure NSG inbound rules
BROKER_1_EXTERNAL_PORT=9094
BROKER_2_EXTERNAL_PORT=9095
BROKER_3_EXTERNAL_PORT=9096

# 22-character KRaft cluster id generated once and reused
KAFKA_CLUSTER_ID=replace-with-kraft-cluster-id
