          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH latest AS (\r\n  SELECT DISTINCT ON (vehicle_id)\r\n         vehicle_id,\r\n         driver_code,\r\n         lat,\r\n         lon,\r\n         speed,\r\n         engine_on,\r\n         fuel,\r\n         mode,\r\n         \"timestamp\"\r\n  FROM vehicle_data_100\r\n  WHERE vehicle_id IN (${vehicle:sqlstring})\r\n  ORDER BY vehicle_id, \"timestamp\" DESC\r\n)\r\nSELECT\r\n  vehicle_id,\r\n  driver_code,\r\n  CASE\r\n    WHEN engine_on = true AND COALESCE(speed, 0) > 0 THEN '운행 중'\r\n    WHEN engine_on = true AND COALESCE(speed, 0) = 0 THEN '정차'\r\n    WHEN engine_on = false THEN '시동 OFF'\r\n    ELSE '상태 미정'\r\n  END AS vehicle_status,\r\n  speed,\r\n  fuel,\r\n  mode,\r\n  CONCAT(lat, ', ', lon) AS location,\r\n  \"timestamp\" AS last_update\r\nFROM latest\r\nORDER BY vehicle_id;",
          "refId": "A",
